+      <div className="app ov:min-h-screen ov:bg-[#f4f5f2]">
+        <TestBackButton />
+        <div id="dining-configurator-full-page-root" className="ov:min-h-screen" />
+      </div>
+    </ViewportWrapper>
+  );
+}
+
+ReactDOM.createRoot(document.getElementById('root')).render(
+  <React.StrictMode>
+    <App />
+  </React.StrictMode>,
+);
+
+export default App;
